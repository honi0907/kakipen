<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="KakiMoni_Client.DisplayPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:canvas="using:Microsoft.Graphics.Canvas.UI.Xaml"
    Background="#0d0d1a"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch">

    <Grid x:Name="RootGrid"
          Background="#0d0d1a"
          HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch">
        <Grid x:Name="CanvasHost"
              Background="White"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch">
            <Image x:Name="BgImage"
                   Stretch="UniformToFill"
                   HorizontalAlignment="Stretch"
                   VerticalAlignment="Stretch"
                   Visibility="Collapsed"
                   IsHitTestVisible="False" />
            <Image x:Name="FillJudgeOverlayImage"
                   Stretch="UniformToFill"
                   HorizontalAlignment="Stretch"
                   VerticalAlignment="Stretch"
                   Visibility="Collapsed"
                   IsHitTestVisible="False" />
            <canvas:CanvasControl x:Name="DrawCanvas"
                                  Draw="DrawCanvas_Draw"
                                  HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  IsHitTestVisible="False" />
            <Image x:Name="ChoiceOverlayImage"
                   Stretch="Uniform"
                   HorizontalAlignment="Stretch"
                   VerticalAlignment="Stretch"
                   Visibility="Collapsed"
                   IsHitTestVisible="False" />
            <Image x:Name="JudgeOverlayImage"
                   Stretch="Uniform"
                   HorizontalAlignment="Stretch"
                   VerticalAlignment="Stretch"
                   Visibility="Collapsed"
                   IsHitTestVisible="False" />
        </Grid>

        <Border x:Name="CoverPanel"
                Background="#0d1b2a"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Visibility="Collapsed" />
    </Grid>
</UserControl>
