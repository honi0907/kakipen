<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="KakiMoni_Client.SetupPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}">

    <Grid>
        <Grid Padding="16,12,16,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Spacing="2" Margin="0,0,0,8">
                <TextBlock Text="KakiMoni 子機"
                           FontSize="22"
                           FontWeight="SemiBold" />
                <TextBlock x:Name="VersionText"
                           FontSize="12"
                           Opacity="0.75" />
            </StackPanel>
            <TextBlock x:Name="StartupText" Visibility="Collapsed" />

            <Grid Grid.Row="1" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="240" />
                    <ColumnDefinition Width="*" MinWidth="240" />
                </Grid.ColumnDefinitions>

                <!-- 左: 接続・ペン・表示 -->
                <StackPanel Grid.Column="0" Spacing="10">
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12">
                        <StackPanel Spacing="8">
                            <TextBlock Text="接続" FontWeight="SemiBold" />
                            <TextBox x:Name="ServerUrlBox"
                                     Header="サーバー URL"
                                     PlaceholderText="http://127.0.0.1:3000"
                                     LostFocus="OnServerUrlChanged" />
                            <NumberBox x:Name="SeatIdBox"
                                       Header="席 ID (1-10)"
                                       Minimum="1"
                                       Maximum="10"
                                       Value="1"
                                       SpinButtonPlacementMode="Inline"
                                       ValueChanged="OnSeatIdChanged" />
                        </StackPanel>
                    </Border>

                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="12">
                        <StackPanel Spacing="8">
                            <TextBlock Text="ペン" FontWeight="SemiBold" />
                            <StackPanel x:Name="PalettePanel" Orientation="Horizontal" Spacing="8" />
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="ペンの太さ" FontSize="12" Opacity="0.9" />
                                    <Slider x:Name="PenSizeSlider"
                                            Minimum="2"
                                            Maximum="40"
                                            StepFrequency="1"
                                            ValueChanged="OnPenSizeChanged" />
                                    <TextBlock x:Name="PenSizeLabel" FontSize="12" Opacity="0.8" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Text="消しゴムの太さ" FontSize="12" Opacity="0.9" />
                                    <Slider x:Name="EraserSizeSlider"
                                            Minimum="4"
                                            Maximum="80"
                                            StepFrequency="1"
                                            ValueChanged="OnEraserSizeChanged" />
                                    <TextBlock x:Name="EraserSizeLabel" FontSize="12" Opacity="0.8" />
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="ツール表示" FontSize="12" Opacity="0.9" Margin="0,2,0,0" />
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <CheckBox x:Name="ShowConfirmButtonCheckBox"
                                          Content="決定"
                                          IsChecked="True"
                                          Checked="OnWritingToolSettingsChanged"
                                          Unchecked="OnWritingToolSettingsChanged" />
                                <CheckBox x:Name="ShowClearButtonCheckBox"
                                          Content="クリア"
                                          IsChecked="True"
                                          Checked="OnWritingToolSettingsChanged"
                                          Unchecked="OnWritingToolSettingsChanged" />
                                <CheckBox x:Name="ShowEraserToolCheckBox"
                                          Content="消しゴム"
                                          IsChecked="True"
                                          Checked="OnWritingToolSettingsChanged"
                                          Unchecked="OnWritingToolSettingsChanged" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- 右: アセット・表示 -->
                <StackPanel Grid.Column="1" Spacing="10">
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12"
                        VerticalAlignment="Top">
                    <StackPanel Spacing="10">
                        <TextBlock Text="アセット確認" FontWeight="SemiBold" />
                        <TextBlock Text="backgrounds / logo フォルダに画像を配置"
                                   FontSize="12"
                                   Opacity="0.75" />

                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="背景"
                                       VerticalAlignment="Center"
                                       Width="36"
                                       FontSize="12"
                                       Opacity="0.85" />
                            <StackPanel Grid.Column="1" Spacing="4">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button x:Name="RefreshBgButton"
                                            Content="確認"
                                            Click="OnRefreshBgClick"
                                            Padding="12,4" />
                                    <ProgressRing x:Name="BgCheckRing"
                                                  Width="18"
                                                  Height="18"
                                                  IsActive="False"
                                                  Visibility="Collapsed" />
                                </StackPanel>
                                <TextBlock x:Name="BgStatusText"
                                           Text="席 ID と URL を入力すると確認できます。"
                                           TextWrapping="WrapWholeWords"
                                           FontSize="12"
                                           Opacity="0.9" />
                            </StackPanel>
                            <Border x:Name="BgPreviewBorder"
                                    Grid.Column="2"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Visibility="Collapsed">
                                <Image x:Name="BgPreviewImage"
                                       Width="112"
                                       Height="63"
                                       Stretch="UniformToFill" />
                            </Border>
                        </Grid>

                        <Border Height="1"
                                Background="{ThemeResource DividerStrokeColorDefaultBrush}"
                                Opacity="0.6" />

                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="ロゴ"
                                       VerticalAlignment="Center"
                                       Width="36"
                                       FontSize="12"
                                       Opacity="0.85" />
                            <StackPanel Grid.Column="1" Spacing="4">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Button x:Name="RefreshLogoButton"
                                            Content="確認"
                                            Click="OnRefreshLogoClick"
                                            Padding="12,4" />
                                    <ProgressRing x:Name="LogoCheckRing"
                                                  Width="18"
                                                  Height="18"
                                                  IsActive="False"
                                                  Visibility="Collapsed" />
                                </StackPanel>
                                <TextBlock x:Name="LogoStatusText"
                                           Text="サーバー URL を入力すると確認できます。"
                                           TextWrapping="WrapWholeWords"
                                           FontSize="12"
                                           Opacity="0.9" />
                            </StackPanel>
                            <Border x:Name="LogoPreviewBorder"
                                    Grid.Column="2"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Visibility="Collapsed">
                                <Image x:Name="LogoPreviewImage"
                                       Width="112"
                                       Height="63"
                                       Stretch="Uniform" />
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12">
                    <StackPanel Spacing="4">
                        <TextBlock Text="表示" FontWeight="SemiBold" />
                        <CheckBox x:Name="WritingFullscreenCheckBox"
                                  Content="書き画面をフルスクリーン"
                                  Checked="OnDisplaySettingsChanged"
                                  Unchecked="OnDisplaySettingsChanged" />
                        <CheckBox x:Name="ExternalOutputEnabledCheckBox"
                                  Content="外部出力を使用する"
                                  Checked="OnDisplaySettingsChanged"
                                  Unchecked="OnDisplaySettingsChanged" />
                        <StackPanel x:Name="ExternalOutputOptionsPanel"
                                    Margin="24,0,0,0"
                                    Spacing="2">
                            <CheckBox x:Name="ExternalAutoPlacementCheckBox"
                                      Content="拡張側に自動配置"
                                      Checked="OnDisplaySettingsChanged"
                                      Unchecked="OnDisplaySettingsChanged" />
                            <CheckBox x:Name="ExternalFullscreenCheckBox"
                                      Content="外部出力をフルスクリーン"
                                      Checked="OnDisplaySettingsChanged"
                                      Unchecked="OnDisplaySettingsChanged" />
                        </StackPanel>
                    </StackPanel>
                </Border>
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="2" Spacing="8" Margin="0,10,0,0">
                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12">
                    <StackPanel Spacing="8">
                        <TextBlock Text="アプリ更新" FontWeight="SemiBold" />
                        <TextBlock x:Name="UpdateStatusText"
                                   Text="未確認"
                                   FontSize="12"
                                   Opacity="0.9"
                                   TextWrapping="WrapWholeWords" />
                        <Button x:Name="OnlineUpdateButton"
                                Content="子機をオンライン更新"
                                Click="OnOnlineUpdateClick"
                                HorizontalAlignment="Left" />
                    </StackPanel>
                </Border>
                <InfoBar x:Name="ErrorBar" IsOpen="False" Severity="Error" />
                <InfoBar x:Name="ConnectionStatusBar"
                         IsOpen="False"
                         Severity="Success"
                         Message="サーバーに接続済みです。書き画面を起動できます。" />
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button x:Name="ServerConnectButton"
                            Grid.Column="0"
                            Content="サーバー接続"
                            Click="OnServerConnectClick"
                            HorizontalAlignment="Stretch"
                            Style="{ThemeResource AccentButtonStyle}" />
                    <Button x:Name="LaunchWritingButton"
                            Grid.Column="1"
                            Content="書き画面を起動"
                            Click="OnLaunchWritingClick"
                            HorizontalAlignment="Stretch"
                            IsEnabled="False" />
                </Grid>
                <Button x:Name="DisconnectButton"
                        Content="サーバー切断"
                        Click="OnDisconnectClick"
                        HorizontalAlignment="Stretch"
                        Visibility="Collapsed" />
            </StackPanel>
        </Grid>

        <Grid x:Name="LaunchOverlay"
              Visibility="Collapsed"
              Background="#CC111827">
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Spacing="16"
                        Padding="24">
                <ProgressRing x:Name="LaunchProgressRing"
                              IsActive="True"
                              Width="40"
                              Height="40" />
                <TextBlock x:Name="LaunchStatusText"
                           Text="サーバーに接続中..."
                           Foreground="White"
                           FontSize="16"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="WrapWholeWords" />
            </StackPanel>
        </Grid>
    </Grid>
</Page>
