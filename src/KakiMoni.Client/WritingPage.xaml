<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="KakiMoni_Client.WritingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:canvas="using:Microsoft.Graphics.Canvas.UI.Xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="#111827">

    <Page.Resources>
        <Style x:Key="WritingClearButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#16a34a" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="MinWidth" Value="88" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Padding="{TemplateBinding Padding}"
                                Opacity="1">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Root"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.88"
                                                             Duration="0:0:0.05" />
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Root"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.75"
                                                             Duration="0:0:0.05" />
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Root"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.4"
                                                             Duration="0:0:0" />
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding Content}"
                                              Foreground="{TemplateBinding Foreground}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WritingConfirmButtonStyle" TargetType="Button" BasedOn="{StaticResource WritingClearButtonStyle}">
            <Setter Property="Background" Value="#dc2626" />
        </Style>

        <Storyboard x:Key="BlackoutStoryboard" RepeatBehavior="Forever" Duration="0:0:2.4">
            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="BlackoutDotsText"
                                           Storyboard.TargetProperty="Text">
                <DiscreteObjectKeyFrame KeyTime="0:0:0" Value="。" />
                <DiscreteObjectKeyFrame KeyTime="0:0:0.8" Value="。。" />
                <DiscreteObjectKeyFrame KeyTime="0:0:1.6" Value="。。。" />
            </ObjectAnimationUsingKeyFrames>
        </Storyboard>
    </Page.Resources>

    <Grid>
        <Grid Padding="16" RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid MinHeight="44">
                <Border x:Name="SeatIdTapArea"
                        Background="Transparent"
                        Padding="4,2"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Tapped="OnSeatIdAreaTapped">
                    <StackPanel Orientation="Vertical" Spacing="2">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <Ellipse x:Name="ConnDot" Width="12" Height="12" Fill="#64748b" />
                            <TextBlock x:Name="SeatLabel" Foreground="White" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock x:Name="HintText"
                                   Foreground="#94a3b8"
                                   FontSize="12"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Border>

                <StackPanel Orientation="Horizontal"
                            Spacing="10"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <Button x:Name="ConfirmButton"
                            Content="決定"
                            Style="{StaticResource WritingConfirmButtonStyle}"
                            Click="OnConfirmClick" />
                    <Button x:Name="ClearButton"
                            Content="クリア"
                            Style="{StaticResource WritingClearButtonStyle}"
                            Click="OnClearClick" />
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            Spacing="8"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <Grid x:Name="EraserToolHost"
                          Width="46"
                          Height="46"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Tapped="OnEraserTapped"
                          ToolTipService.ToolTip="消しゴム">
                        <ProgressRing x:Name="EraserReturnProgress"
                                      Width="46"
                                      Height="46"
                                      IsIndeterminate="False"
                                      IsActive="True"
                                      Maximum="100"
                                      Minimum="0"
                                      Value="100"
                                      Foreground="#22d3ee"
                                      Visibility="Collapsed" />
                        <Border x:Name="EraserToolRing"
                                Width="40"
                                Height="40"
                                CornerRadius="20"
                                BorderThickness="0"
                                BorderBrush="#22d3ee"
                                Background="Transparent"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                            <Border x:Name="EraserToolFace"
                                    Width="36"
                                    Height="36"
                                    CornerRadius="18"
                                    Background="#334155"
                                    BorderBrush="#1e293b"
                                    BorderThickness="2"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE75C;"
                                          FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                          FontSize="16"
                                          Foreground="White"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                            </Border>
                        </Border>
                    </Grid>
                    <StackPanel x:Name="ColorToolbar"
                                Orientation="Horizontal"
                                Spacing="6"
                                VerticalAlignment="Center" />
                </StackPanel>
            </Grid>

            <Grid x:Name="CanvasHost" Grid.Row="1" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#111827">
                <Border x:Name="CanvasFrame"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        BorderThickness="0"
                        Background="#111827">
                    <Grid>
                        <Image x:Name="BackgroundImage"
                               Stretch="UniformToFill"
                               HorizontalAlignment="Stretch"
                               VerticalAlignment="Stretch"
                               IsHitTestVisible="False" />
                        <Image x:Name="FillJudgeOverlayImage"
                               Stretch="UniformToFill"
                               Visibility="Collapsed"
                               IsHitTestVisible="False" />
                        <canvas:CanvasControl x:Name="DrawCanvas" Draw="DrawCanvas_Draw"
                                              PointerPressed="DrawCanvas_PointerPressed"
                                              PointerMoved="DrawCanvas_PointerMoved"
                                              PointerReleased="DrawCanvas_PointerReleased"
                                              PointerCanceled="DrawCanvas_PointerReleased" />
                        <Image x:Name="ChoiceOverlayImage"
                               Stretch="Uniform"
                               Visibility="Collapsed"
                               IsHitTestVisible="False" />
                        <Image x:Name="JudgeOverlayImage"
                               Stretch="Uniform"
                               Visibility="Collapsed"
                               IsHitTestVisible="False" />
                        <Border x:Name="WritingBlackoutOverlay"
                                Background="Black"
                                Visibility="Collapsed"
                                IsHitTestVisible="False">
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Bottom"
                                        Margin="24"
                                        Spacing="0">
                                <TextBlock Text="のぞき見中"
                                           Foreground="White"
                                           FontSize="40"
                                           FontFamily="UD Digi Kyokasho N"
                                           VerticalAlignment="Center" />
                                <Grid VerticalAlignment="Center">
                                    <TextBlock Text="。。。"
                                               Foreground="White"
                                               FontSize="40"
                                               FontFamily="UD Digi Kyokasho N"
                                               Opacity="0"
                                               IsHitTestVisible="False" />
                                    <TextBlock x:Name="BlackoutDotsText"
                                               Text="。"
                                               Foreground="White"
                                               FontSize="40"
                                               FontFamily="UD Digi Kyokasho N"
                                               HorizontalAlignment="Left"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>
                <Border x:Name="LockOverlay" Background="#000000" Visibility="Collapsed">
                    <TextBlock x:Name="LockMessageText"
                               Text="ロックされました"
                               Foreground="White"
                               FontSize="28"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>
            </Grid>
        </Grid>

        <Grid x:Name="LaunchOverlay"
              Visibility="Collapsed"
              Background="#CC111827">
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Spacing="16"
                        Padding="24">
                <ProgressRing x:Name="LaunchProgressRing"
                              IsActive="True"
                              Width="40"
                              Height="40" />
                <TextBlock x:Name="LaunchStatusText"
                           Text="サーバーに接続中..."
                           Foreground="White"
                           FontSize="16"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="WrapWholeWords" />
            </StackPanel>
        </Grid>
    </Grid>
</Page>
