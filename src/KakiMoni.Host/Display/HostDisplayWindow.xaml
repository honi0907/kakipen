<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="KakiMoni_Host.Display.HostDisplayWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:display="using:KakiMoni_Host.Display">

    <Grid x:Name="RootGrid" Background="Black">
        <Image x:Name="BackgroundImage"
               Stretch="UniformToFill"
               Visibility="Collapsed"
               IsHitTestVisible="False" />
        <Canvas x:Name="CellsCanvas" />
        <StackPanel x:Name="WaitingPanel"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="8">
            <TextBlock Text="レイアウト未設定"
                       Foreground="#6b7280"
                       FontSize="24"
                       HorizontalAlignment="Center" />
            <TextBlock Text="コンパネからレイアウトを適用してください"
                       Foreground="#374151"
                       FontSize="14"
                       HorizontalAlignment="Center" />
        </StackPanel>
    </Grid>
</Window>
