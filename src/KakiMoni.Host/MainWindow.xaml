<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="KakiMoni_Host.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:KakiMoni_Host"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="KakiMoni.Host"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar x:Name="AppTitleBar" Title="KakiMoni.Host">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="Assets/AppIcon.ico" />
            </TitleBar.IconSource>
        </TitleBar>

        <Frame x:Name="RootFrame" Grid.Row="1" />

        <Grid x:Name="StopOverlay"
              Grid.Row="0"
              Grid.RowSpan="2"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch"
              Canvas.ZIndex="1000"
              Visibility="Collapsed"
              Background="#CC111827">
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Spacing="16"
                        Padding="24">
                <ProgressRing x:Name="StopProgressRing"
                              IsActive="True"
                              Width="40"
                              Height="40" />
                <TextBlock Text="サーバー停止中..."
                           Foreground="White"
                           FontSize="16"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
