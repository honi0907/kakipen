<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="KakiMoni_Host.CompanelPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:KakiMoni_Host.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{StaticResource CompanelBgBrush}"
    SizeChanged="OnPageSizeChanged">

    <Grid RowSpacing="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" MinHeight="140" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- TopBar -->
        <Border Grid.Row="0"
                BorderBrush="{StaticResource CompanelSectionBorderBrush}"
                BorderThickness="0,0,0,2"
                Padding="10,6,16,6">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="KakiMoni 親機"
                               FontSize="17"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource CompanelTitleBrush}"
                               VerticalAlignment="Center" />
                    <Border x:Name="ConnBadge"
                            Background="#374151"
                            CornerRadius="8"
                            Padding="8,3"
                            VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <Ellipse x:Name="HubConnDot" Width="7" Height="7" Fill="#64748b" />
                            <TextBlock x:Name="ConnBadgeText"
                                       Text="Hub未接続"
                                       FontSize="11"
                                       Foreground="#e5e7eb"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                    <TextBlock x:Name="ConnText"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource CompanelMutedTextBrush}"
                               FontSize="11"
                               Opacity="0.85"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="280" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center">
                    <TextBlock Text="Session:"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource CompanelMutedTextBrush}"
                               FontSize="12" />
                    <Border Style="{StaticResource CompanelSaveFieldBorderStyle}" Width="58">
                        <NumberBox x:Name="SaveSessionBox"
                                   Style="{StaticResource CompanelSaveNumberBoxStyle}"
                                   Minimum="1"
                                   Maximum="99"
                                   LostFocus="OnSaveSessionLostFocus" />
                    </Border>
                    <TextBlock Text="Q:"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource CompanelMutedTextBrush}"
                               FontSize="12" />
                    <Border Style="{StaticResource CompanelSaveFieldBorderStyle}" Width="68">
                        <NumberBox x:Name="SaveCounterBox"
                                   Style="{StaticResource CompanelSaveNumberBoxStyle}"
                                   Minimum="0"
                                   Maximum="9999"
                                   LostFocus="OnSaveCounterLostFocus" />
                    </Border>
                    <ComboBox x:Name="NetworkAdapterCombo"
                              MinWidth="140"
                              MaxWidth="200"
                              Height="32"
                              DisplayMemberPath="Label"
                              VerticalAlignment="Center"
                              SelectionChanged="OnNetworkSettingChanged" />
                    <TextBlock x:Name="UrlText"
                               VerticalAlignment="Center"
                               Foreground="#6b7280"
                               FontSize="11"
                               IsTextSelectionEnabled="True"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="200" />
                    <Button x:Name="CopyChildUrlButton"
                            Content="コピー"
                            Height="28"
                            Padding="8,2"
                            VerticalAlignment="Center"
                            Click="OnCopyChildUrlClick" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- GlobalCtrl -->
        <Border Grid.Row="1"
                BorderBrush="{StaticResource CompanelSectionBorderBrush}"
                BorderThickness="0,0,0,2"
                Padding="10,6,16,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <Grid>
                        <Button x:Name="GoButton"
                                Content="GO"
                                Style="{StaticResource BtnGoStyle}"
                                Click="OnGoClick" />
                        <Border x:Name="SelectedBadge"
                                Background="#06b6d4"
                                CornerRadius="3"
                                Padding="4,1"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="0,-6,0,0"
                                Visibility="Collapsed">
                            <TextBlock x:Name="SelectedBadgeText"
                                       FontSize="10"
                                       Foreground="White"
                                       FontWeight="SemiBold" />
                        </Border>
                    </Grid>
                    <Button x:Name="JudgeGoButton"
                            Content="判定GO"
                            Style="{StaticResource BtnJudgeGoStyle}"
                            Click="OnJudgeGoClick" />
                    <Button x:Name="ClearJudgeButton"
                            Content="判定解除"
                            Style="{StaticResource BtnBlueOutlineStyle}"
                            Click="OnClearJudgeClick" />
                    <Border Width="2" Height="72" Background="#6b7280" Margin="2,0" />
                    <ComboBox x:Name="ChoiceComboBox"
                              MinWidth="140"
                              MaxWidth="200"
                              Height="36"
                              VerticalAlignment="Center"
                              PlaceholderText="―なし―"
                              DisplayMemberPath="FileName"
                              SelectionChanged="OnChoiceSelectionChanged" />
                    <Border Width="128"
                            Height="72"
                            VerticalAlignment="Center"
                            CornerRadius="3"
                            BorderBrush="#4b5563"
                            BorderThickness="1"
                            Background="White">
                        <Image x:Name="ChoiceThumbImage"
                               Stretch="Uniform"
                               Margin="3"
                               Visibility="Collapsed" />
                    </Border>
                    <Button x:Name="SendChoiceButton"
                            Content="選択肢送信"
                            Style="{StaticResource BtnBlueOutlineStyle}"
                            Click="OnSendChoiceClick" />
                    <Button x:Name="ClearChoiceButton"
                            Content="選択肢解除"
                            Style="{StaticResource BtnBlueOutlineStyle}"
                            Click="OnClearChoiceClick" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="6"
                            VerticalAlignment="Center">
                    <Button x:Name="StandbyButton"
                            Content="スタンバイ"
                            Style="{StaticResource BtnStandbyStyle}"
                            Click="OnStandbyClick" />
                    <Border Width="2" Height="72" Background="#6b7280" />
                    <Button x:Name="SettingsButton"
                            Content="⚙ 設定"
                            Style="{StaticResource BtnBlueOutlineStyle}"
                            Click="OnSettingsClick" />
                    <Button x:Name="LayoutButton"
                            Content="レイアウト"
                            Style="{StaticResource BtnBlueOutlineStyle}"
                            Click="OnLayoutClick" />
                    <Border Width="2" Height="72" Background="#6b7280" />
                    <Button x:Name="LauncherButton"
                            Content="ソフト終了"
                            Style="{StaticResource BtnSubtleStyle}"
                            Click="OnLauncherClick" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Seats grid (no scroll — fills remaining height) -->
        <Border x:Name="SeatsHost"
                Grid.Row="2"
                Padding="8,6"
                SizeChanged="OnSeatsHostSizeChanged">
            <ItemsRepeater x:Name="SeatRepeater"
                           HorizontalAlignment="Stretch"
                           VerticalAlignment="Stretch">
                <ItemsRepeater.Layout>
                    <UniformGridLayout x:Name="SeatGridLayout"
                                       Orientation="Horizontal"
                                       MaximumRowsOrColumns="5"
                                       MinItemWidth="120"
                                       MinItemHeight="64" />
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="controls:SeatCardModel">
                        <controls:SeatCardView Model="{x:Bind}" />
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>
        </Border>

        <!-- Action board -->
        <controls:SeatActionBoard x:Name="ActionBoard" Grid.Row="3" />
    </Grid>
</Page>
