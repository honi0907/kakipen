<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="KakiMoni_Host.Controls.SeatCardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:canvas="using:Microsoft.Graphics.Canvas.UI.Xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Top"
    SizeChanged="OnCardSizeChanged">

    <Border x:Name="CardBorder"
            Padding="4"
            CornerRadius="4"
            Background="#252525"
            BorderBrush="#4b5563"
            BorderThickness="1"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Top">
        <Grid RowSpacing="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                <Border x:Name="SeatNumBadge"
                        Width="18"
                        Height="18"
                        CornerRadius="9"
                        Background="#dc2626"
                        VerticalAlignment="Center">
                    <TextBlock x:Name="SeatNumText"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="10"
                               FontWeight="Bold"
                               Foreground="White" />
                </Border>
                <TextBlock x:Name="SeatNameText"
                           FontSize="10"
                           FontWeight="SemiBold"
                           Foreground="#e5e7eb"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="72" />
                <TextBlock x:Name="StatusText"
                           FontSize="10"
                           Foreground="#9ca3af"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
                <FontIcon x:Name="LockIcon"
                          Glyph="&#xE72E;"
                          FontSize="10"
                          Foreground="#fbbf24"
                          VerticalAlignment="Center"
                          Visibility="Collapsed" />
            </StackPanel>

            <Border x:Name="PreviewFrame"
                    Grid.Row="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Top"
                    Background="White"
                    DoubleTapped="OnPreviewDoubleTapped">
                <Grid>
                    <Image x:Name="BackgroundImage"
                           Stretch="Uniform"
                           IsHitTestVisible="False" />
                    <Image x:Name="FillJudgeOverlayImage"
                           Stretch="UniformToFill"
                           Visibility="Collapsed"
                           IsHitTestVisible="False" />
                    <canvas:CanvasControl x:Name="PreviewCanvas" Draw="PreviewCanvas_Draw" />
                    <Image x:Name="ChoiceOverlayImage"
                           Stretch="Uniform"
                           Visibility="Collapsed"
                           IsHitTestVisible="False" />
                    <Image x:Name="JudgeOverlayImage"
                           Stretch="Uniform"
                           Visibility="Collapsed"
                           IsHitTestVisible="False" />
                    <TextBlock x:Name="PlaceholderText"
                               Text="未接続"
                               FontSize="11"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="#6b7280"
                               Visibility="Collapsed" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
