<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="KakiMoni_Host.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}">

    <Grid Padding="20,16,20,12" RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Spacing="2">
            <TextBlock Text="KakiMoni 親機"
                       Style="{ThemeResource TitleTextBlockStyle}" />
            <TextBlock Text="サーバー起動・コンパネ・外部出力"
                       Style="{ThemeResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <TextBlock x:Name="VersionText"
                       Style="{ThemeResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <TextBlock x:Name="StartupText" Visibility="Collapsed" />
        </StackPanel>

        <Grid Grid.Row="1" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" MinWidth="400" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="4">
                <ListView x:Name="NavList"
                          SelectionMode="Single"
                          IsItemClickEnabled="True"
                          SelectionChanged="OnNavSelectionChanged">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="12,10" />
                            <Setter Property="CornerRadius" Value="6" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListViewItem Content="サーバー" Tag="server" />
                    <ListViewItem Content="その他" Tag="other" />
                </ListView>
            </Border>

            <Border Grid.Column="1"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="DetailTitleText"
                               FontSize="18"
                               FontWeight="SemiBold" />
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Spacing="0">
                            <!-- サーバー -->
                            <StackPanel x:Name="ServerSection" Spacing="8">
                                <NumberBox x:Name="PortBox"
                                           Header="ポート"
                                           Value="3000"
                                           Minimum="1024"
                                           Maximum="65535"
                                           SpinButtonPlacementMode="Inline"
                                           HorizontalAlignment="Stretch" />
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.35*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <ComboBox x:Name="NetworkAdapterCombo"
                                              Grid.Column="0"
                                              Header="使用ネットワーク"
                                              DisplayMemberPath="Label"
                                              HorizontalAlignment="Stretch"
                                              SelectionChanged="OnNetworkSettingChanged" />
                                    <ComboBox x:Name="NetworkPreferenceCombo"
                                              Grid.Column="1"
                                              Header="自動時の優先"
                                              HorizontalAlignment="Stretch"
                                              SelectionChanged="OnNetworkSettingChanged" />
                                </Grid>
                                <Grid ColumnSpacing="8" RowSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Button x:Name="ServerToggleButton"
                                            Grid.Row="0"
                                            Grid.Column="0"
                                            Grid.ColumnSpan="2"
                                            Content="サーバー ON"
                                            Style="{StaticResource AccentButtonStyle}"
                                            HorizontalAlignment="Stretch"
                                            Click="OnServerToggleClick" />
                                    <Button x:Name="CompanelButton"
                                            Grid.Row="1"
                                            Grid.Column="0"
                                            Content="コンパネを開く"
                                            HorizontalAlignment="Stretch"
                                            Click="OnCompanelClick"
                                            IsEnabled="False" />
                                    <Button x:Name="DisplayToggleButton"
                                            Grid.Row="1"
                                            Grid.Column="1"
                                            Content="外部出力 ON"
                                            HorizontalAlignment="Stretch"
                                            Click="OnDisplayToggleClick"
                                            IsEnabled="False" />
                                </Grid>

                                <Border Height="1"
                                        Margin="0,8"
                                        Background="{ThemeResource DividerStrokeColorDefaultBrush}"
                                        Opacity="0.6" />

                                <InfoBar x:Name="StatusInfoBar"
                                         IsOpen="True"
                                         IsClosable="False"
                                         Severity="Informational"
                                         Title="停止中" />
                                <TextBlock x:Name="DisplayStatusText"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Visibility="Collapsed" />
                                <StackPanel x:Name="UrlPanel" Spacing="4" Visibility="Collapsed">
                                    <TextBlock Style="{ThemeResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               Text="子機 URL" />
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock x:Name="ChildUrlText"
                                                   Style="{ThemeResource BodyTextBlockStyle}"
                                                   FontSize="13"
                                                   IsTextSelectionEnabled="True"
                                                   TextWrapping="NoWrap"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center" />
                                        <Button x:Name="CopyChildUrlButton"
                                                Content="コピー"
                                                Click="OnCopyChildUrlClick"
                                                VerticalAlignment="Center" />
                                    </StackPanel>
                                </StackPanel>
                                <TextBlock x:Name="EmptyHintText"
                                           Style="{ThemeResource BodyTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Text="サーバーを起動すると、子機の接続状況が表示されます。"
                                           Margin="0,4,0,0" />
                                <StackPanel x:Name="SeatsPanel"
                                            Spacing="6"
                                            HorizontalAlignment="Stretch"
                                            Visibility="Collapsed">
                                    <TextBlock x:Name="SeatsSummaryText"
                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="10"
                                            HorizontalAlignment="Stretch">
                                        <Grid x:Name="SeatsGrid"
                                              HorizontalAlignment="Stretch"
                                              ColumnDefinitions="*,*,*,*,*"
                                              RowDefinitions="Auto,Auto"
                                              ColumnSpacing="6"
                                              RowSpacing="6" />
                                    </Border>
                                    <TextBlock x:Name="SeatsUpdatedText"
                                               Style="{ThemeResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               HorizontalAlignment="Right" />
                                </StackPanel>
                            </StackPanel>

                            <!-- その他 -->
                            <StackPanel x:Name="OtherSection"
                                        Spacing="8"
                                        Visibility="Collapsed">
                                <CheckBox x:Name="CompanelFullscreenCheck"
                                          Content="コンパネをフルスクリーンで開く"
                                          Checked="OnCompanelFullscreenChanged"
                                          Unchecked="OnCompanelFullscreenChanged" />
                                <Border Height="1"
                                        Background="{ThemeResource DividerStrokeColorDefaultBrush}"
                                        Opacity="0.6"
                                        Margin="0,4" />
                                <TextBlock Text="アプリ更新"
                                           Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                <TextBlock x:Name="UpdateStatusText"
                                           Style="{ThemeResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextWrapping="WrapWholeWords"
                                           Text="未確認" />
                                <Grid ColumnSpacing="8" RowSpacing="8" MaxWidth="480">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Button x:Name="OpenAssetsFolderButton"
                                            Grid.Row="0"
                                            Grid.Column="0"
                                            Content="アセットフォルダを開く"
                                            HorizontalAlignment="Stretch"
                                            Click="OnOpenAssetsFolderClick" />
                                    <Button x:Name="OpenSavesFolderButton"
                                            Grid.Row="0"
                                            Grid.Column="1"
                                            Content="保存フォルダを開く"
                                            HorizontalAlignment="Stretch"
                                            Click="OnOpenSavesFolderClick" />
                                    <Button x:Name="OnlineUpdateButton"
                                            Grid.Row="1"
                                            Grid.Column="0"
                                            Grid.ColumnSpan="2"
                                            Content="親機をオンライン更新"
                                            HorizontalAlignment="Stretch"
                                            Click="OnOnlineUpdateClick" />
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
