<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="KakiMoni_Host.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}">

    <ScrollViewer Padding="24">
        <StackPanel Spacing="16" MaxWidth="520">
            <TextBlock Text="KakiMoni 親機" FontSize="28" FontWeight="SemiBold" />
            <TextBlock x:Name="StartupText" Opacity="0.7" Text="起動中..." />

            <NumberBox x:Name="PortBox" Header="ポート" Value="3000" Minimum="1024" Maximum="65535" SpinButtonPlacementMode="Inline" />

            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button x:Name="StartButton" Content="サーバー起動" Click="OnStartClick" />
                <Button x:Name="StopButton" Content="停止" Click="OnStopClick" IsEnabled="False" />
                <Button x:Name="CompanelButton" Content="コンパネを開く" Click="OnCompanelClick" IsEnabled="False" />
            </StackPanel>

            <TextBlock x:Name="StatusText" Text="停止中" TextWrapping="WrapWholeWords" />
            <TextBlock x:Name="UrlText" Opacity="0.8" TextWrapping="WrapWholeWords" />

            <StackPanel x:Name="SeatsPanel" Spacing="8" Visibility="Collapsed">
                <TextBlock Text="子機接続状況" FontSize="16" FontWeight="SemiBold" />
                <TextBlock x:Name="SeatsSummaryText" Opacity="0.85" />
                <Grid
                    x:Name="SeatsGrid"
                    ColumnDefinitions="*,*,*,*,*"
                    RowDefinitions="Auto,Auto"
                    ColumnSpacing="6"
                    RowSpacing="6" />
                <TextBlock x:Name="SeatsUpdatedText" FontSize="12" Opacity="0.6" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
