<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="KakiMoni_Host.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource LayerOnAcrylicFillColorDefaultBrush}">

    <ScrollViewer Padding="24,20,24,24"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <Grid MaxWidth="920" RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Spacing="4">
                <TextBlock Text="KakiMoni 親機"
                           Style="{ThemeResource TitleTextBlockStyle}" />
                <TextBlock Text="サーバー起動・コンパネ・外部出力"
                           Style="{ThemeResource BodyTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock x:Name="VersionText"
                           Style="{ThemeResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock x:Name="StartupText" Visibility="Collapsed" />
            </StackPanel>

            <Grid Grid.Row="1" ColumnSpacing="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="280" MaxWidth="360" />
                    <ColumnDefinition Width="1.25*" MinWidth="380" />
                </Grid.ColumnDefinitions>

                <!-- 左: サーバー・状態 -->
                <StackPanel Grid.Column="0" Spacing="16">
                    <StackPanel Spacing="12">
                        <TextBlock Text="サーバー"
                                   Style="{ThemeResource BodyStrongTextBlockStyle}" />

                        <NumberBox x:Name="PortBox"
                                   Header="ポート"
                                   Value="3000"
                                   Minimum="1024"
                                   Maximum="65535"
                                   SpinButtonPlacementMode="Inline"
                                   HorizontalAlignment="Stretch" />

                        <ComboBox x:Name="NetworkAdapterCombo"
                                  Header="使用ネットワーク"
                                  DisplayMemberPath="Label"
                                  HorizontalAlignment="Stretch"
                                  SelectionChanged="OnNetworkSettingChanged" />

                        <ComboBox x:Name="NetworkPreferenceCombo"
                                  Header="自動時の優先"
                                  HorizontalAlignment="Stretch"
                                  SelectionChanged="OnNetworkSettingChanged" />

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Name="StartButton"
                                    Content="サーバー起動"
                                    Style="{StaticResource AccentButtonStyle}"
                                    Click="OnStartClick" />
                            <Button x:Name="StopButton"
                                    Content="停止"
                                    Click="OnStopClick"
                                    IsEnabled="False" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Name="CompanelButton"
                                    Content="コンパネを開く"
                                    Click="OnCompanelClick"
                                    IsEnabled="False" />
                            <Button x:Name="DisplayToggleButton"
                                    Content="外部出力 ON"
                                    Click="OnDisplayToggleClick"
                                    IsEnabled="False" />
                        </StackPanel>
                    </StackPanel>

                    <Border Height="1"
                            Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                    <StackPanel Spacing="10">
                        <TextBlock Text="状態"
                                   Style="{ThemeResource BodyStrongTextBlockStyle}" />

                        <InfoBar x:Name="StatusInfoBar"
                                 IsOpen="True"
                                 IsClosable="False"
                                 Severity="Informational"
                                 Title="停止中" />

                        <TextBlock x:Name="DisplayStatusText"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Visibility="Collapsed" />

                        <StackPanel x:Name="UrlPanel" Spacing="6" Visibility="Collapsed">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Style="{ThemeResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               Text="子機 URL" />
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock x:Name="ChildUrlText"
                                                   Style="{ThemeResource BodyTextBlockStyle}"
                                                   FontSize="13"
                                                   IsTextSelectionEnabled="True"
                                                   TextWrapping="WrapWholeWords"
                                                   VerticalAlignment="Center" />
                                        <Button x:Name="CopyChildUrlButton"
                                                Content="コピー"
                                                Click="OnCopyChildUrlClick"
                                                VerticalAlignment="Center" />
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Style="{ThemeResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               Text="コンパネ" />
                                    <TextBlock x:Name="CompanelUrlText"
                                               Style="{ThemeResource BodyTextBlockStyle}"
                                               FontSize="13"
                                               IsTextSelectionEnabled="True"
                                               TextWrapping="WrapWholeWords" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </StackPanel>

                    <Border Height="1"
                            Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                    <StackPanel Spacing="8">
                        <TextBlock Text="アプリ更新"
                                   Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <TextBlock x:Name="UpdateStatusText"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="WrapWholeWords"
                                   Text="未確認" />
                        <Button x:Name="OnlineUpdateButton"
                                Content="親機をオンライン更新"
                                Click="OnOnlineUpdateClick"
                                HorizontalAlignment="Left" />
                    </StackPanel>
                </StackPanel>

                <!-- 右: 子機接続状況 -->
                <StackPanel Grid.Column="1" Spacing="10" VerticalAlignment="Top">
                    <TextBlock x:Name="EmptyHintText"
                               Style="{ThemeResource BodyTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Text="サーバーを起動すると、子機の接続状況が表示されます。"
                               VerticalAlignment="Center"
                               Margin="0,40,0,0" />

                    <StackPanel x:Name="SeatsPanel" Spacing="8" Visibility="Collapsed">
                        <TextBlock Text="子機接続状況"
                                   Style="{ThemeResource BodyStrongTextBlockStyle}" />
                        <TextBlock x:Name="SeatsSummaryText"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="10">
                            <Grid x:Name="SeatsGrid"
                                  ColumnDefinitions="*,*,*,*,*"
                                  RowDefinitions="Auto,Auto"
                                  ColumnSpacing="6"
                                  RowSpacing="6" />
                        </Border>

                        <TextBlock x:Name="SeatsUpdatedText"
                                   Style="{ThemeResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   HorizontalAlignment="Right" />
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
